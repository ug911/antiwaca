# ============================================
# WISE CLIENT TRACKER - Environment Config
# Copy to .env and fill in actual values
# ============================================

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wise_tracker
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── LLM Provider ────────────────────────────
# Set ONE provider: ollama | openai | anthropic | grok
LLM_PROVIDER=ollama

# Ollama (local, no API key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (uncomment if using)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic / Claude (uncomment if using)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Grok / xAI (uncomment if using)
# GROK_API_KEY=xai-...
# GROK_MODEL=grok-3-mini
# GROK_BASE_URL=https://api.x.ai/v1

# ── Team ────────────────────────────────────
# Phone numbers with country code (e.g. +919876543210)
PHONE_UTKARSH=+91...
PHONE_MUBEEN=+91...
PHONE_RAHUL=+91...
PHONE_SANDHYA=+91...

# Twilio (optional - for urgent phone call alerts)
# TWILIO_SID=AC...
# TWILIO_TOKEN=...
# TWILIO_PHONE=+1...

# Dashboard
DASHBOARD_PORT=3000
